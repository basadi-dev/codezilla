# Codezilla Environment Variables
# Copy this file to .env and fill in your values
# DO NOT COMMIT .env TO VERSION CONTROL

# --- LLM Provider Selection ---
# Override the default provider (ollama, openai, anthropic, gemini)
# LLM_PROVIDER=ollama

# --- Ollama / Ollama Cloud ---
# Ensure base url matches your config or defaults to cloud
OLLAMA_BASE_URL="https://ollama.com"
OLLAMA_API_KEY="your-api-key-here"

# For basic auth
# OLLAMA_USERNAME="your-username"
# OLLAMA_PASSWORD="your-password"

# --- OpenAI (or OpenAI-compatible APIs) ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Anthropic ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Google Gemini ---
# GEMINI_API_KEY=...

# --- Web Search ---
# The webSearch tool uses an embedded metasearch engine (DuckDuckGo HTML + Wikipedia + optional Bing).
# No API key is required. Configure via metasearch: block in config.yaml.
#
# The fetchURL tool uses Jina AI Reader (https://jina.ai/reader/) to convert URLs to markdown.
# No API key required.
